# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=claims
POSTGRES_USER=claims_user
POSTGRES_PASSWORD=change_me_in_production

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_in_production

# ── LLM Provider ──────────────────────────────────────────────────
# anthropic (дефолт) — требует ANTHROPIC_API_KEY
# gemini             — требует GEMINI_API_KEY, дешевле для высокого объёма
LLM_PROVIDER=anthropic

# ── AI APIs ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=                  # заполнить при LLM_PROVIDER=gemini
# Модель Gemini (extraction + decision + indexer). Тариф в дашборде подтянется
# автоматически по имени: gemini-2.5-flash ($0.30/$2.50) | gemini-3.5-flash ($1.50/$9.00)
GEMINI_MODEL=gemini-2.5-flash

# ── Себестоимость LLM ($/1M токенов) — FALLBACK ──────────────────
# Известные модели (gemini-2.5-flash, gemini-3.5-flash, claude-sonnet-4-6...)
# берут точную цену из таблицы _LLM_TOKEN_COST_PER_MTOK в config.py —
# смена GEMINI_MODEL автоматически меняет тариф в дашборде.
# Эти переменные применяются ТОЛЬКО для модели, которой нет в таблице.
# Актуальные цены: ai.google.dev/gemini-api/docs/pricing | anthropic.com/pricing
ANTHROPIC_INPUT_COST_PER_MTOK=3.00
ANTHROPIC_OUTPUT_COST_PER_MTOK=15.00
GEMINI_INPUT_COST_PER_MTOK=0.30
GEMINI_OUTPUT_COST_PER_MTOK=2.50

# Google аутентификация через Application Default Credentials (ADC)
# Файл создаётся командой: gcloud auth application-default login
# Windows:  GCLOUD_CONFIG_DIR=%APPDATA%\gcloud
# Linux/Mac: не задавать (дефолт /root/.config/gcloud внутри контейнера)
# GCLOUD_CONFIG_DIR=

# ── OCR (Google Document AI) ──────────────────────────────────────
# Формат: projects/{project_id}/locations/{location}/processors/{processor_id}
GCP_DOCUMENT_AI_PROCESSOR=projects/insurance-claims-dev/locations/us/processors/FORM_PARSER

# ── Embeddings (локальная модель) ─────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large
TRANSFORMERS_CACHE=/app/.cache/huggingface

# ── Storage ───────────────────────────────────────────────────────
STORAGE_BUCKET=claims-documents-dev
STORAGE_PROVIDER=local          # local | gcs | s3  (local только для dev)

# ── Кор-система Lite GROUP ────────────────────────────────────────
# Аутентификация: POST {CORE_API_AUTH_URL}/api/User/authenticate → Bearer-токен
# Токен кэшируется в Redis (TTL=1ч), обновляется автоматически при 401.

# LiteMed API (данные полисов через getpolicylist):
#   ТЕСТ: http://192.168.0.249:8077
#   ПРОД: http://192.168.0.250:1010
CORE_API_BASE_URL=http://192.168.0.249:8077

# Auth-сервер (если отличается от CORE_API_BASE_URL):
#   ТЕСТ: пусто (= CORE_API_BASE_URL, то же 192.168.0.249:8077)
#   ПРОД: http://10.0.204.10:1010
CORE_API_AUTH_URL=

# Claims API — ОТДЕЛЬНЫЙ сервис Lite GROUP (другой порт, HTTPS, своя аутентификация):
#   Auth: POST {CORE_API_CLAIMS_BASE_URL}/LiteApi/LiteAuthJSON → {"token": "..."}
#   Data: POST {CORE_API_CLAIMS_BASE_URL}/LiteApi/LiteServiceJSON (ClaimParsing_UNI)
#   ТЕСТ: https://192.168.0.249:4443
#   ПРОД: https://192.168.0.250:7777
CORE_API_CLAIMS_BASE_URL=https://192.168.0.249:4443

# SSL-сертификат Claims API самоподписанный (внутренняя сеть) → проверку отключить
CORE_API_CLAIMS_VERIFY_SSL=false

# Пропустить ClaimParsing_UNI (dev-режим когда Claims API недоступен).
# True → статус по AI-решению, Innum="SKIPPED".
# НИКОГДА не ставить True в production.
CORE_API_SKIP_CLAIMS_SUBMIT=false

CORE_API_USERNAME=webplatform
CORE_API_PASSWORD=change_me_in_production

# Отдельные учётные данные для Claims API (LiteApi/LiteAuthJSON).
# Если пусто — используются CORE_API_USERNAME / CORE_API_PASSWORD.
# Заполнить если Claims API требует другой логин/пароль (получить у команды Lite GROUP).
CORE_API_CLAIMS_USERNAME=
CORE_API_CLAIMS_PASSWORD=
CORE_API_TIMEOUT=10
CORE_API_RETRY=3

# ── fkind коды документов (ClaimParsing_UNI) ─────────────────────
# 11 = ფორმა N 100    (Форма 100)
# 12 = ექიმის დანიშნულება (Направление врача)
# 14 = კვლევის პასუხები  (Результаты исследований / чек)
#
# ── ConfigKind (вид направления) ──────────────────────────────────
# 1 = направление
# 2 = акт возмещения  ← используется в проекте
# 3 = гарантийное письмо

# ── Конфигурация системы ──────────────────────────────────────────
# Период ожидания: false = отключить проверку (например для тестирования или по договору без периода)
DECISION_WAITING_PERIOD_ENABLED=true

CONFIDENCE_AUTO_APPROVE=0.85
CONFIDENCE_MANUAL_REVIEW=0.80
CONFIDENCE_REQUEST_DOCS=0.70
MANUAL_REVIEW_AMOUNT_THRESHOLD=500.00
MANUAL_REVIEW_CURRENCY=GEL
DOCUMENT_RETENTION_MONTHS=84
AUDIT_LOG_RETENTION_MONTHS=84
APPEAL_WINDOW_DAYS=30
APPEAL_REVIEW_SLA_DAYS=5

# ── Антифрод ──────────────────────────────────────────────────────
FRAUD_FREQUENCY_WINDOW_DAYS=30
FRAUD_FREQUENCY_MAX_CLAIMS=10
FRAUD_AMOUNT_SIGMA_THRESHOLD=3.0

# ── Quality Gate (проверка качества скана) ───────────────────────
# Прод-дефолты ниже; для тестов на слабых сканах можно снизить
# (QUALITY_MIN_RESOLUTION_DPI=50, QUALITY_MAX_BLUR_SCORE=10).
QUALITY_MIN_RESOLUTION_DPI=150
QUALITY_MAX_BLUR_SCORE=100.0

# ── Webhook от кор-системы ────────────────────────────────────────
# Пусто = проверка подписи отключена (только dev)
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET_KEY=

# ── Extraction: rule-based ────────────────────────────────────────
# true → детерминированный экстрактор (дешевле), confidence ниже порога → fallback на LLM
EXTRACTION_USE_RULES=false
EXTRACTION_RULES_MIN_CONFIDENCE=0.60   # порог confidence rule-экстрактора → fallback на LLM

# ── Портал (JWT) ──────────────────────────────────────────────────
PORTAL_JWT_EXPIRE_HOURS=8
# Создание пользователя портала:
#   docker compose exec api python -m scripts.create_user \
#       --tenant-slug default --email user@example.com --full-name "Name" --role operator

# ── Приложение ────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change_me_in_production

# audit_log защищён от DELETE/UPDATE на уровне БД (compliance-требование).
# false снимает защиту через `python -m scripts.toggle_audit_log_lock` —
# ТОЛЬКО для очистки тестовых данных в dev; скрипт откажется выполняться
# при ENVIRONMENT=production.
AUDIT_LOG_IMMUTABLE=true

# ── API-аутентификация (platform.api_keys) ───────────────────────
# Каждый запрос к /v1/* требует заголовок X-API-Key (в production — строго,
# в development без ключа используется дефолтный тенант с предупреждением).
# Создание ключа:
#   docker compose exec api python -m scripts.create_api_key \
#       --tenant-slug default --name "Medsystem production"
API_KEY_HEADER=X-API-Key
API_RATE_LIMIT_DEFAULT_RPM=60
